#!/usr/bin/env bash
set -euo pipefail

# Versioned commit-msg hook template.
# Bootstrap should replace or tighten the placeholder convention below.

msg_file="${1:?commit message file required}"

if ! grep -Eq '<commit-message-regex>' "$msg_file"; then
  echo "Blocked: commit message does not match project convention" >&2
  echo "Replace <commit-message-regex> during bootstrap." >&2
  exit 1
fi
